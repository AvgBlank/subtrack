{
  "name": "@subtrack/api",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "tsc && tsc-alias",
    "start": "cross-env NODE_ENV=production bun dist/src/index.js",
    "dev": "cross-env NODE_ENV=development bun run --hot src/index.ts",
    "clean": "rm -rf dist/ .turbo/ src/generated",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "check-types": "tsc --noEmit",
    "test": "bun test",
    "healthcheck": "bun run dist/src/healthy.js",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.6.0",
    "@subtrack/shared": "workspace:*",
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cross-env": "^10.1.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "jose": "^6.2.2",
    "prisma": "^7.6.0",
    "tsc-alias": "^1.8.16",
    "ua-parser-js": "^2.0.8",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@subtrack/eslint-config": "workspace:*",
    "@subtrack/typescript-config": "workspace:*",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^8.2.3",
    "@types/express": "^5.0.6",
    "@types/express-serve-static-core": "^5.1.1",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.4",
    "typescript": "^5.9.3"
  }
}
