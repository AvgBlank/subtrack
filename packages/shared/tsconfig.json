{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@subtrack/typescript-config/base.json",
  "compilerOptions": {
    "outDir": "dist",
    "types": ["bun"],
    "rootDir": "src",
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo",
    "declaration": true,
    "declarationMap": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "**/__tests__"]
}
